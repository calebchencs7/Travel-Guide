# Map provider: osm or amap
VITE_MAP_PROVIDER=amap
# You can get a free amap key and security code at https://console.amap.com/dev/index
# AMap Web service key
VITE_AMAP_KEY=
# AMap JS API security code (recommended for JS API v2)
VITE_AMAP_SECURITY=
# Optional custom Nominatim endpoint for osm mode，only used when VITE_MAP_PROVIDER is set to osm.
VITE_NOMINATIM_ENDPOINT=https://nominatim.openstreetmap.org/search
